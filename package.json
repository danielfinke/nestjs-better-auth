{
	"name": "@thallesp/nestjs-better-auth",
	"version": "2.5.0",
	"description": "Better Auth for NestJS",
	"author": "Thalles Passos",
	"license": "MIT",
	"engines": {
		"node": ">=22.22.1 <23"
	},
	"keywords": [
		"nestjs",
		"better-auth",
		"auth",
		"nestjs-better-auth"
	],
	"type": "module",
	"scripts": {
		"build": "unbuild",
		"prepack": "bun run unbuild",
		"lint": "biome lint",
		"format": "biome format",
		"check": "biome check",
		"test": "bun run test:express && bun run test:fastify",
		"test:watch": "vitest",
		"test:express": "TEST_HTTP_ADAPTER=express vitest run",
		"test:fastify": "TEST_HTTP_ADAPTER=fastify vitest run",
		"test:adapters": "sh -c 'status=0; bun run test:express & pid1=$!; bun run test:fastify & pid2=$!; wait $pid1 || status=$?; wait $pid2 || status=$?; exit $status'"
	},
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"import": "./dist/index.mjs",
			"default": "./dist/index.mjs"
		}
	},
	"files": [
		"dist"
	],
	"devDependencies": {
		"@apollo/server": "^5.0.0",
		"@as-integrations/express5": "^1.1.2",
		"@as-integrations/fastify": "^3.1.0",
		"@biomejs/biome": "2.2.4",
		"@faker-js/faker": "^10.0.0",
		"@nestjs/apollo": "^13.1.0",
		"@nestjs/graphql": "^13.1.0",
		"@nestjs/platform-fastify": "^11.1.6",
		"@nestjs/platform-express": "^11.1.6",
		"@nestjs/platform-socket.io": "^11.1.6",
		"@nestjs/testing": "^11.1.6",
		"@nestjs/websockets": "^11.1.6",
		"@swc/cli": "^0.7.8",
		"@swc/core": "^1.13.20",
		"@tsconfig/node22": "^22.0.2",
		"@types/bun": "latest",
		"@types/express": "^5.0.3",
		"@types/supertest": "^6.0.3",
		"@vitest/coverage-v8": "^3.2.4",
		"fastify": "^5.6.1",
		"graphql": "^16.11.0",
		"qs": "^6.14.0",
		"reflect-metadata": "^0.2.2",
		"socket.io": "^4.8.1",
		"socket.io-client": "^4.8.1",
		"supertest": "^7.1.4",
		"unbuild": "^3.6.1",
		"unplugin-swc": "^1.5.7",
		"vitest": "^3.2.4"
	},
	"peerDependencies": {
		"@nestjs/common": "^11.1.6",
		"@nestjs/core": "^11.1.6",
		"@nestjs/graphql": "^13.1.0",
		"@nestjs/websockets": "^11.1.6",
		"better-auth": ">=1.5.0 <2.0.0",
		"express": "^5.1.0",
		"graphql": "^16.11.0",
		"qs": "^6.14.0",
		"typescript": "^5.9.2"
	},
	"peerDependenciesMeta": {
		"@nestjs/graphql": {
			"optional": true
		},
		"@nestjs/websockets": {
			"optional": true
		},
		"graphql": {
			"optional": true
		},
		"qs": {
			"optional": true
		}
	}
}
